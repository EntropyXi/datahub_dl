{
    "name": "sr_ffhq",
    "phase": "train", // train or val
    "gpu_ids": [
        0
    ],
    "path": { //set the path
        "log": "logs",
        "tb_logger": "tb_logger",
        "results": "results",
        "checkpoint": "checkpoint",
        "resume_state": null
        // "resume_state": "experiments/sr_ffhq_210806_204158/checkpoint/I640000_E37" //pretrain model or training state
    },
    "datasets": {
        "train": {
            "name": "FFHQ",
            "mode": "HR", // whether need LR img
            "dataroot": "dataset/ffhq_16_128",
            "datatype": "img", //lmdb or img, path of img files
            "l_resolution": 16, // low resolution need to super_resolution
            "r_resolution": 128, // high resolution
            "batch_size": 1,
            "num_workers": 1,
            "use_shuffle": true,
            "data_len": 40 // first 40 images for training
        },
        "val": {
            "name": "FFHQ_val",
            "mode": "LRHR",
            "dataroot": "dataset/ffhq_16_128_val",
            "datatype": "img",
            "l_resolution": 16,
            "r_resolution": 128,
            "data_len": 10 // data length in validation
        }
    },
    "model": {
        "which_model_G": "resshift", // use the ddpm, sr3 or resshift network structure
        "finetune_norm": false,
        "unet": {
            "in_channel": 6,
            "out_channel": 3,
            "inner_channel": 64,
            "channel_multiplier": [
                1,
                2,
                4,
                8,
                8
            ],
            "attn_res": [
                16
            ],
            "res_blocks": 2,
            "dropout": 0.2
        },
        "beta_schedule": { // ResShift shift schedule
            "train": {
                "n_timestep": 15,
                "kappa": 0.05,
                "p": 0.8,
                "eta_1": 1e-5,
                "eta_T": 1.0
            },
            "val": {
                "n_timestep": 15,
                "kappa": 0.05,
                "p": 0.8,
                "eta_1": 1e-5,
                "eta_T": 1.0
            }
        },
        "diffusion": {
            "image_size": 128,
            "channels": 3, //sample channel
            "conditional": true // unconditional generation or unconditional generation(super_resolution)
        }
    },
    "train": {
        "n_iter": 10000,
        "val_freq": 200,
        "save_checkpoint_freq": 1000,
        "print_freq": 10,
        "optimizer": {
            "type": "adam",
            "lr": 1e-4
        },
        "ema_scheduler": { // not used now
            "step_start_ema": 5000,
            "update_ema_every": 1,
            "ema_decay": 0.9999
        }
    },
    "wandb": {
        "project": "sr_ffhq"
    }
}